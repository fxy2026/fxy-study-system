# Copy this to .env and fill in your credentials
# DO NOT commit .env to git!

# AI API (e.g., SJTU models API or OpenAI-compatible)
AI_API_URL=https://models.example.com/api/v1/chat/completions
AI_API_KEY=sk-your-api-key-here

# Canvas LMS
CANVAS_API_URL=https://your-canvas.edu/api/v1
CANVAS_TOKEN=your-canvas-token

# Vikunja (task management)
VIKUNJA_URL=http://localhost:8086/api/v1
VIKUNJA_TOKEN=your-vikunja-token

# Memos (quick notes)
MEMOS_API=http://localhost:8083/api/v1
MEMOS_TOKEN=your-memos-token

# Bark (iOS push notifications)
BARK_KEY=your-bark-key

# WebDAV
WEBDAV_USER=your-username
WEBDAV_PASS=your-password

# Vault path
VAULT_DIR=/root/webdav-vault
