{
  "manifest_version": 3,
  "name": "FXY Study Helper",
  "description": "Save Gemini conversations, clip web pages, track video courses — all synced to Obsidian",
  "version": "2.0.0",
  "permissions": ["storage", "activeTab", "contextMenus"],
  "host_permissions": [
    "https://gemini.google.com/*",
    "https://kb.xpy.me/*",
    "https://*.googleusercontent.com/*",
    "https://*.googleapis.com/*",
    "https://*.google.com/*",
    "https://www.bilibili.com/*",
    "https://*/*",
    "http://*/*"
  ],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["turndown.min.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.bilibili.com/video/*"],
      "js": ["bilibili.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["clipper.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
